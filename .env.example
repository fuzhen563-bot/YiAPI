PORT=3000
DEBUG=false

# Database - SQLite (default, no external dependency)
# For MySQL, uncomment and fill:
# SQL_DSN=root:123456@tcp(localhost:3306)/yiapi?charset=utf8mb4&parseTime=True&loc=Local

# Redis (optional, for multi-node deployment)
# REDIS_CONN_STRING=redis://localhost:6379/0

# Proxy for upstream API requests
# HTTPS_PROXY=http://localhost:7890

# System
THEME=shadcn
# SYNC_FREQUENCY=600

# Rate limits
# GLOBAL_API_RATE_LIMIT=480
# GLOBAL_WEB_RATE_LIMIT=240

# Initial root token (optional)
# INITIAL_ROOT_TOKEN=
# INITIAL_ROOT_ACCESS_TOKEN=

# Payment - YiPay Integration
# PAYMENT_ENABLED=true
# YIPAY_API_URL=https://your-epay.com
# YIPAY_PID=1000
# YIPAY_KEY=your_md5_key
# YIPAY_NOTIFY_URL=http://your-domain.com/api/payment/notify/yipay
# YIPAY_RETURN_URL=http://your-domain.com/

# Direct Top-Up via URL
# DIRECT_TOPUP_ENABLED=true
# DIRECT_TOPUP_KEY=your_secret_key
